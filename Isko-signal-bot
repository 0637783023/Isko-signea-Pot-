from telegram import Update
from telegram.ext import Application, CommandHandler, ContextTypes

# Geli token-kaaga rasmiga ah ee aad ka soo qaadday BotFather labada calaamadood " " dhexdooda
TOKEN = "GELI_TOKEN_KAAGA_HALKAN"

async def start(update: Update, context: ContextTypes.DEFAULT_TYPE):
    await update.message.reply_text("Ku soo dhawoow Isko signals bot! 👋")

def main():
    app = Application.builder().token(TOKEN).build()
    app.add_handler(CommandHandler("start", start))
    print("Bot-ku hadda waa shaqaynayaa...")
    app.run_polling()

if __name__ == '__main__':
    main()

